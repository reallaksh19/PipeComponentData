            TitleArray(3) = "S - Taper Flange Beams"
            TitleArray(4) = "Channels"
            TitleArray(5) = "Angles - Equal and Unequal"
            TitleArray(6) = "Square Tubing"
            TitleArray(7) = "Rectangular Tubing"
            TitleArray(8) = "Pipe"


            TitleArrayQty = 8


            frmPipedata.Combo1_Tab1.Text = TitleArray(1)
            frmPipedata.Combo1_Tab2.Text = TitleArray(2)
            frmPipedata.Combo1_Tab3.Text = TitleArray(3)
            frmPipedata.Combo1_Tab4.Text = TitleArray(4)
            frmPipedata.Combo1_Tab5.Text = TitleArray(5)
            frmPipedata.Combo1_Tab6.Text = TitleArray(6)
            frmPipedata.Combo1_Tab7.Text = TitleArray(7)
            frmPipedata.Combo1_Tab8.Text = TitleArray(8)


            frmPipedata.Combo1_Tab1.Visible = True
            frmPipedata.Combo1_Tab2.Visible = True
            frmPipedata.Combo1_Tab3.Visible = False
            frmPipedata.Combo1_Tab4.Visible = False
            frmPipedata.Combo1_Tab5.Visible = False
            frmPipedata.Combo1_Tab6.Visible = False
            frmPipedata.Combo1_Tab7.Visible = False
            frmPipedata.Combo1_Tab8.Visible = False
            frmPipedata.Combo1_Tab9.Visible = False
            frmPipedata.Combo1_Tab10.Visible = False

            frmPipedata.Combo1_Tab11.Visible = False
            frmPipedata.Combo1_Tab12.Visible = False
            frmPipedata.Combo1_Tab13.Visible = False
            frmPipedata.Combo1_Tab14.Visible = False
            frmPipedata.Combo1_Tab15.Visible = False
            frmPipedata.Combo1_Tab16.Visible = False
            frmPipedata.Combo1_Tab17.Visible = False
