
 'Stus''''''''''''''''''''''''''''''

        MainSize = 16
        ASMEClass$ = "300#"
        Face$ = "RF"
        Sch$ = "STD"
        SmallSize = 6
        Rating$ = "3000#"
        APIRatingIndex% = 1
        DinClass$ = "40"
        Table$ = "D"
        ValveClass$ = "800#"
        PipeNominalBore$ = "6"
        PipeWallThk$ = "7.11"


        For x = 1 To 8

            ActiveTab$ = "Stus" & Trim$(Str$(x))
            SaveSettings()

        Next

        ActiveTab$ = "Stus1"
        SaveActiveSubSector()



























 ''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''
