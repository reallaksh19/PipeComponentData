 Public Sub Stus1()

        SubTab$ = "Stus1a"

        TabbCount = 1

        TabbQty = 8

        DesigCombosGrtjStyle()

        MinMainSize = 4

        LowerLimit = 3

        HigherLimit = MainSize

        DataBaseName1 = "Stus1_W_Shape_InchPound"

        DataFolder1$ = "Stus"

        Sensor1 = 3

        LoadDataBase1()

        If MainSize > LineQtyDbase1 Then
            MainSize = LineQtyDbase1
            SaveSettings()
            Clicker()
        End If

        SortLists()

        If ActiveDba$(1, MainSize, Sensor1) = "" Or ActiveDba$(1, MainSize, Sensor1) = "N/A" Then
            ErrorMessageNuts()
        Else
            Stus1_Headers()
            GotoForm()
        End If

    End Sub


















    Public Sub Stus1_Headers()

        frmPipedata.Label1.Text = ActiveDba$(1, MainSize%, ListCol) & " lb/ft " & Title$

        TempString$ = Val(ActiveDba$(1, MainSize%, 1)) * WeightFactor
        FormatDim()

        frmPipedata.Label2.Text = "Weight = " & TempString$ & " " & WeightSign$

        frmPipedata.Label3.Text = ""
        frmPipedata.Label4.Text = ""
        frmPipedata.Label5.Text = ""
        frmPipedata.Label6.Text = ""

        frmPipedata.Label7.Text = ActivitySpecLong$
        frmPipedata.Label7.Top = frmPipedata.StatusStrip1.Top - frmPipedata.Label7.Height - 8
        frmPipedata.Label7.Width = frmPipedata.StatusStrip1.Width / 2
        frmPipedata.Label7.Left = (frmPipedata.StatusStrip1.Left + frmPipedata.StatusStrip1.Width) - frmPipedata.Label7.Width - 8

    End Sub