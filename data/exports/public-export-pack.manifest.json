{
  "schema": "pipedata-public-export-pack/v1",
  "phase": "DB_PHASE_17",
  "purpose": "Stable public artifact/API manifest for downstream PipeComponentData integrations.",
  "policy": {
    "exactMatchOnly": true,
    "noEngineeringFallback": true,
    "rawSourceTreePublished": false,
    "missingValues": "null_or_UNAVAILABLE",
    "provenanceRequired": true
  },
  "publicApis": [
    {
      "module": "pipe-component-data",
      "export": "lookupComponentExact",
      "kind": "function",
      "stability": "stable",
      "contract": "source-backed exact component lookup"
    },
    {
      "module": "pipe-component-data",
      "export": "LOOKUP_STATUS",
      "kind": "constant",
      "stability": "stable",
      "contract": "lookup status enum"
    }
  ],
  "publicArtifacts": [
    { "path": "data/exports/db-export-manifest.json", "pagesPath": "data/exports/db-export-manifest.json", "kind": "EXPORT_MANIFEST", "family": "ALL" },
    { "path": "data/indexes/component-search.index.json", "pagesPath": "data/indexes/component-search.index.json", "kind": "SEARCH_INDEX", "family": "ALL" },
    { "path": "data/search/component-aliases.json", "pagesPath": "data/search/component-aliases.json", "kind": "ALIAS_INDEX", "family": "ALL" },
    { "path": "data/audit/db-coverage-dashboard.json", "pagesPath": "data/audit/db-coverage-dashboard.json", "kind": "COVERAGE_AUDIT", "family": "ALL" },
    { "path": "data/normalized/pipes.json", "pagesPath": "data/normalized/pipes.json", "kind": "NORMALIZED_DATA", "family": "PIPE" },
    { "path": "data/normalized/flanges.json", "pagesPath": "data/normalized/flanges.json", "kind": "NORMALIZED_DATA", "family": "FLANGE" },
    { "path": "data/normalized/valves.json", "pagesPath": "data/normalized/valves.json", "kind": "NORMALIZED_DATA", "family": "VALVE" },
    { "path": "data/normalized/fittings.json", "pagesPath": "data/normalized/fittings.json", "kind": "NORMALIZED_DATA", "family": "FITTING" },
    { "path": "data/normalized/gaskets.json", "pagesPath": "data/normalized/gaskets.json", "kind": "NORMALIZED_DATA", "family": "GASKET" },
    { "path": "data/normalized/supports.json", "pagesPath": "data/normalized/supports.json", "kind": "NORMALIZED_DATA", "family": "SUPPORT" }
  ],
  "forbiddenArtifacts": [
    {
      "path": "docs/Pipedata/Database",
      "reason": "Raw source database tree must not be exposed through normal Studio or Pages artifacts."
    }
  ]
}
